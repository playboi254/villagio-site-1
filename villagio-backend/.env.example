# ─── Villagio Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/villagio

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars

# ── CORS ──────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ── Redis (optional – caching disabled if not set) ────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5

# ── CDN (optional – leave blank to serve from /uploads directly) ──────────────
CDN_URL=

# ── Web Push Notifications ─────────────────────────────────────────────────────
VAPID_EMAIL=mailto:admin@villagio.co.ke
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# ── Sentry (optional – error monitoring) ─────────────────────────────────────
SENTRY_DSN=

# ── Misc ──────────────────────────────────────────────────────────────────────
# Add any other environment-specific config here
